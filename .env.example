# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:29092

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=alive
POSTGRES_PASSWORD=alive
POSTGRES_DB=alive

# ── Anomaly Detection ──────────────────────────────────────────────────────────
# Seconds above which a metric event triggers a HighLatency anomaly
LATENCY_THRESHOLD=2.0
# rule-only | ml-only | hybrid
DETECTION_MODE=rule-only
# LLM confidence above which actions auto-execute (below this → human approval queue)
ANOMALY_CONFIDENCE_THRESHOLD=0.8

# ── LLM Provider ───────────────────────────────────────────────────────────────
# openai | anthropic
LLM_PROVIDER=openai
# Model name for the chosen provider (e.g. gpt-4o-mini, claude-haiku-4-5-20251001)
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-key-here
ANTHROPIC_API_KEY=your-key-here

# ── Observability ──────────────────────────────────────────────────────────────
# OTel collector endpoint — Jaeger all-in-one OTLP gRPC port
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
