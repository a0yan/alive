# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:29092

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=alive
POSTGRES_PASSWORD=alive
POSTGRES_DB=alive

# ── Anomaly Detection ──────────────────────────────────────────────────────────
# Seconds above which a metric event triggers a HighLatency anomaly
LATENCY_THRESHOLD=2.0
# rule-only | ml-only | hybrid
DETECTION_MODE=rule-only
# LLM confidence above which actions auto-execute (below this → human approval queue)
ANOMALY_CONFIDENCE_THRESHOLD=0.8

# ── LLM Provider ───────────────────────────────────────────────────────────────
# openai | anthropic | groq | together | ollama | huggingface
LLM_PROVIDER=openai
# Model for the chosen provider. Leave blank to use the provider's default.
#   openai → gpt-4o-mini   anthropic → claude-haiku-4-5-20251001
#   groq → llama-3.1-8b-instant   ollama → mistral
LLM_MODEL=gpt-4o-mini
# Override the provider's base URL (advanced: self-hosted endpoint or proxy).
# LLM_BASE_URL=
# Provider API keys — only the active provider's key is required.
OPENAI_API_KEY=your-key-here
ANTHROPIC_API_KEY=your-key-here
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# HF_TOKEN=
#
# Local offline demo (no API key needed):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=mistral
#   Run `ollama serve` on the host; Docker reaches it via host.docker.internal.

# ── Observability ──────────────────────────────────────────────────────────────
# OTel collector endpoint — Jaeger all-in-one OTLP gRPC port
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
